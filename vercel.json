{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/screenshot.js": { "memory": 1024, "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/s/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
